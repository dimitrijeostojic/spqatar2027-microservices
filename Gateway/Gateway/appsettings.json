  {
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "team-route": {
        "ClusterId": "team-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/team/{**catch-all}"
        }
      },
      "group-route": {
        "ClusterId": "team-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/group/{**catch-all}"
        }
      },
      "match-route": {
        "ClusterId": "match-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/match/{**catch-all}"
        }
      },
      "stadium-route": {
        "ClusterId": "stadium-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/stadium/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://auth-service:8080/"
          }
        }
      },
      "team-cluster": {
        "Destinations": {
          "team-destination": {
            "Address": "http://team-service:8080/"
          }
        }
      },
      "match-cluster": {
        "Destinations": {
          "match-destination": {
            "Address": "http://match-service:8080/"
          }
        }
      },
      "stadium-cluster": {
        "Destinations": {
          "stadium-destination": {
            "Address": "http://stadium-service:8080/"
          }
        }
      }
    }
  }
}
